# OmniTerm .gitignore

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.pyc

# ── Virtual environments ──
.venv/
venv/
ENV/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# ── OS ──
Thumbs.db
Desktop.ini
.DS_Store

# ── Build output (executables, DLLs, packages) ──
build/
dist/
dist_nuitka/
OUT/
output/
installer_output/

# ── PyInstaller generated (keep OmniTerm.spec tracked) ──
*.spec.bak
*.manifest

# ── Nuitka ──
nuitka-crash-report.xml
*.ilk
*.pdb
*.obj
*.exp
*.lib

# ── Temp ──
C:\Temp\nbuild/

# ── Logs & runtime ──
*.log
errors.txt
test/
